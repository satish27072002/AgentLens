# ─── AgentLens Backend — Environment Variables ───
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./agentlens.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/agentlens

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000

# Auth0 — get these from https://manage.auth0.com
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.agentlens.dev
